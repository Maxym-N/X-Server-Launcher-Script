# Description: 
#   Detects installed video cards and allows the user to choose 
#   a startup option for the X server interactively or via numbered input.
# -----------------------------------------------------------------------------

set -euo pipefail

# --- Step 1: Detect video cards ---
echo "Detected video cards in the system:"
lspci | grep -E "VGA|3D" || echo "No video cards detected."
echo

# --- Step 2: X server startup options ---
options=(
    "startx"
    "startx -- -ignoreABI"
    "startx -- -ignoreABI -config amdgpu.conf"
    "startx -- -ignoreABI -config radeon.conf"
    "startx -- -ignoreABI -config nouveau.conf"
    "startx -- -ignoreABI -config nvidia.conf"
    "startx -- -ignoreABI -config intel.conf"
    "startx -- -ignoreABI -config modesetting.conf"
    "startx -- -ignoreABI -config fbdev.conf"
    "startx -- -ignoreABI -config vesa.conf"
)

# --- Step 3: Determine recommended option ---
recommended="startx -- -ignoreABI -config modesetting.conf"  # fallback

if lspci | grep -iq "AMD"; then
    if lspci | grep -iq "Radeon"; then
        recommended="startx -- -ignoreABI -config radeon.conf"
    else
        recommended="startx -- -ignoreABI -config amdgpu.conf"
    fi
elif lspci | grep -iq "Intel"; then
    recommended="startx -- -ignoreABI -config intel.conf"
elif lspci | grep -iq "NVIDIA"; then
    if command -v nvidia-smi >/dev/null 2>&1; then
        recommended="startx -- -ignoreABI -config nvidia.conf"
    else
        recommended="startx -- -ignoreABI -config nouveau.conf"
    fi
fi

echo "Recommended X server startup option (based on detected video cards):"
echo "  $recommended"
echo

# --- Step 4: User selection ---
echo "Choose an X server startup option:"

if command -v fzf >/dev/null 2>&1; then
    choice=$(printf "%s\n" "${options[@]}" | fzf --prompt="Select > ")
else
    # Numbered list
    for i in "${!options[@]}"; do
        prefix=""
        [[ "${options[i]}" == "$recommended" ]] && prefix="* "
        printf "%2d) %s%s\n" $((i+1)) "$prefix" "${options[i]}"
    done

    while true; do
        read -r -p "Enter the number of your choice: " num
        if [[ "$num" =~ ^[0-9]+$ ]] && (( num >= 1 && num <= ${#options[@]} )); then
            choice="${options[$((num-1))]}"
            break
        else
            echo "Invalid input. Please enter a number between 1 and ${#options[@]}."
        fi
    done
fi

echo
echo "Launching: $choice"
echo

# --- Step 5: Immediate execution ---
eval "$choice"
